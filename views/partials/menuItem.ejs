<div class="menu-item-card">
    <img src="<%= item.img %>"alt="" class="menu-img">
    <h2 class="menu-item-name"><%= item.name %></h2>
    <p class="menu-item-desc"><%= item.description %></p>
    <div class="menu-btn-container">
        <a href="/menu/<%= item.slug %>" class="detail"><button class="menu-btn details">See Details</button></a>
        <a href="/order" class="order-now"><button class="menu-btn order">Order Now</button></a>
    </div>
</div>